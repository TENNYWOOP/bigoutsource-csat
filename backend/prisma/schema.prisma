generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id         String     @id @default(uuid())
  name       String     @unique
  code       String     @unique @default("SYS")
  created_at DateTime   @default(now())
  auditLogs  AuditLog[]
  surveys    Survey[]
  users      User[]
}

model Role {
  id         String   @id @default(uuid())
  name       String   @unique
  is_global  Boolean  @default(false)
  created_at DateTime @default(now())
  users      User[]
}

model User {
  id            String      @id @default(uuid())
  name          String
  email         String      @unique
  role_id       String
  department_id String?
  job_title     String?
  auditLogs     AuditLog[]
  department    Department? @relation(fields: [department_id], references: [id])
  role          Role        @relation(fields: [role_id], references: [id])
}

model Survey {
  id            String           @id @default(uuid())
  slug          String           @unique @default(uuid())
  title         String
  description   String?
  status        String
  department_id String
  created_by    String
  created_at    DateTime         @default(now())
  department    Department       @relation(fields: [department_id], references: [id])
  responses     SurveyResponse[]
  sections      SurveySection[]
}

model SurveySection {
  id            String           @id @default(uuid())
  survey_id     String
  title         String
  section_order Int
  questions     SurveyQuestion[]
  survey        Survey           @relation(fields: [survey_id], references: [id], onDelete: Cascade)
}

model QuestionType {
  id            String           @id
  key           String
  label         String
  config_schema String
  questions     SurveyQuestion[]
}

model SurveyQuestion {
  id             String           @id @default(uuid())
  section_id     String
  type_id        String
  label          String
  required       Boolean          @default(false)
  question_order Int
  config         String
  answers        ResponseAnswer[]
  section        SurveySection    @relation(fields: [section_id], references: [id], onDelete: Cascade)
  type           QuestionType     @relation(fields: [type_id], references: [id])
}

model SurveyResponse {
  id           String           @id @default(uuid())
  survey_id    String
  submitted_at DateTime         @default(now())
  metadata     String?
  answers      ResponseAnswer[]
  survey       Survey           @relation(fields: [survey_id], references: [id], onDelete: Cascade)
}

model ResponseAnswer {
  id          String         @id @default(uuid())
  response_id String
  question_id String
  value       String
  question    SurveyQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)
  response    SurveyResponse @relation(fields: [response_id], references: [id], onDelete: Cascade)
}

model AuditLog {
  id                 String      @id @default(uuid())
  timestamp          DateTime    @default(now())
  user_id            String
  action_description String
  category           String
  ip_address         String
  department_id      String?
  department         Department? @relation(fields: [department_id], references: [id])
  user               User        @relation(fields: [user_id], references: [id])
}
